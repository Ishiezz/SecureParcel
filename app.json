{
  "expo": {
    "name": "SecureParcel",
    "slug": "SecureParcel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-premium.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-premium.png",
      "resizeMode": "contain",
      "backgroundColor": "#12182B"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SecureParcel needs camera access to scan QR codes for secure package pickup."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-premium.png",
        "backgroundColor": "#12182B"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SecureParcel needs camera access to scan QR codes."
        }
      ],
      "@sentry/react-native"
    ],
    "web": {
      "favicon": "./assets/favicon-premium.png"
    }
  }
}
